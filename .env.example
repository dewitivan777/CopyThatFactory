# SMTP settings for contact form email delivery.
SMTP_HOST=mail.copythatfactory.co.za
SMTP_PORT=465
SMTP_USER=hello@copythatfactory.co.za
SMTP_PASS=

# Recipient for contact form submissions.
CONTACT_TO_EMAIL=hello@copythatfactory.co.za

# reCAPTCHA v3 secret key — server-side only, NEVER expose this in client code.
# Get it from https://www.google.com/recaptcha/admin alongside your site key.
RECAPTCHA_SECRET_KEY=
