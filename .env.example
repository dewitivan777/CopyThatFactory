# Email delivery for the contact form.
# The contact API route (src/app/api/contact/route.ts) uses Resend if a key is present.
# Sign up at https://resend.com to get a key, then copy this file to `.env.local`.
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=hello@copythatfactory.co.za

# The verified "from" address for outbound mail (must be a domain verified in Resend).
CONTACT_FROM_EMAIL=website@copythatfactory.co.za

# reCAPTCHA v3 secret key — server-side only, NEVER expose this in client code.
# Get it from https://www.google.com/recaptcha/admin alongside your site key.
RECAPTCHA_SECRET_KEY=6LfZ9D0tAAAAADWAj12K9Eq6HlLWWcHcYMRIIB6E
